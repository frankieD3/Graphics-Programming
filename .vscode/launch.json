{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug VulkanEngine",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/VulkanEngine.exe",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [ ],
            "console": "externalTerminal",
            "preLaunchTask": "build-debug",
            "symbolSearchPath": "${workspaceFolder}/build",
            "sourceMap": {
                "*": "${workspaceFolder}/src"
            },
            "logging": {
                "engineLogging": true
            }
        }
    ]
}